# Copy this file to `.env` (for `vercel dev`) - real values also need to be set in the
# Vercel project's dashboard (Settings -> Environment Variables) for deployed builds.
# Both are server-side only (read in api/contact.ts), never exposed to the browser bundle.

# Resend API key - https://resend.com/api-keys
RESEND_API_KEY=

# The inbox contact form submissions should be delivered to.
CONTACT_TO_EMAIL=

# Optional, local testing only - set to "true" to skip the real Resend call (logs the
# payload instead). Lets you resubmit the form repeatedly without spending Resend's 100/day
# free-tier quota. Do NOT set this in the Vercel project's real environment variables, or
# production submissions will silently stop being delivered.
EMAIL_DRY_RUN=
