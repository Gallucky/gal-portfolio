{
    "compilerOptions": {
        "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.api.tsbuildinfo",
        "target": "ES2023",
        "lib": ["ES2023"],
        "module": "ESNext",
        "types": ["node"],
        "skipLibCheck": true,
        "composite": true,

        /* Bundler mode - matches tsconfig.node.json's settings for this repo's other
           Node-side (non-browser) TypeScript. */
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,

        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["./*.ts"]
}
