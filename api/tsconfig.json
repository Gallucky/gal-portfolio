{
    "compilerOptions": {
        "target": "ES2023",
        "lib": ["ES2023"],
        "module": "ESNext",
        "types": ["node"],
        "skipLibCheck": true,

        /* Bundler mode - matches tsconfig.node.json's settings for this repo's other
           Node-side (non-browser) TypeScript. */
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,

        /* Deliberately NOT `composite`/`tsBuildInfoFile`/wired into the root tsconfig's
           `references` - those only make sense for a project consumed by (or feeding into
           the incremental build graph of) another TS project, and nothing in `src/` ever
           imports from `api/`. Vercel bundles/transpiles api/contact.ts itself at deploy
           time (via esbuild, not this config) - this file exists purely so this folder can
           be type-checked on its own: `npx tsc -p api/tsconfig.json`. */

        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["./*.ts"]
}
